# ─────────────────────────────────────────────────────────────────────────
# Evo — PRODUCTION environment (DigitalOcean Droplet)
#
# On the droplet:
#   cp deploy/env.production.example .env
#   nano .env                       # fill in the values below
#
# .env is gitignored — real keys never get committed.
# ─────────────────────────────────────────────────────────────────────────

# --- Public URLs -----------------------------------------------------------
# The URL the BROWSER uses to reach the backend. Baked into the frontend at
# build time, so re-run `docker compose ... up -d --build` after changing it.
#
#   IP-only (no TLS):   http://<DROPLET_IP>:8000
#   With a domain:      https://api.your-domain.com   (see docker-compose.caddy.yml)
NEXT_PUBLIC_API_URL=http://REPLACE_WITH_DROPLET_IP:8000

# Public origin of the frontend (CORS / link building).
#   IP-only:            http://<DROPLET_IP>:3000
#   With a domain:      https://your-domain.com
FRONTEND_URL=http://REPLACE_WITH_DROPLET_IP:3000

# --- LLM layer (OpenRouter) — LIVE ----------------------------------------
OPENROUTER_API_KEY=sk-or-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
LLM_FAST_MODEL=openai/gpt-4o-mini

# --- Evo2 sequence model — LIVE (NVIDIA NIM 40B) --------------------------
EVO2_MODE=nim_api
NVIDIA_API_KEY=nvapi-REPLACE_ME

# --- Protein structure — LIVE (ESMFold public API) ------------------------
STRUCTURE_MODE=esmfold

# --- NCBI E-utilities (always live; key just raises rate limits) ----------
NCBI_API_KEY=
NCBI_EMAIL=mohammedasrar_ali@trendmicro.com
NCBI_TOOL=evo

# --- Infrastructure --------------------------------------------------------
# Redis runs as a compose service; the backend override sets REDIS_URL and
# SESSION_STORE_MODE=redis automatically — no need to set them here.

# --- Durable persistence (MongoDB Atlas) — LIVE ---------------------------
# IMPORTANT: add the DROPLET's public IP to Atlas → Network Access → Add IP,
# or the TLS handshake is rejected and the store silently stays disabled.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=evo
