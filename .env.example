# ─────────────────────────────────────────────────────────────────────────
# Proteus - environment configuration
# Copy this file to `.env` (repo root) and/or `backend/.env` and fill in keys.
# Everything works in a deterministic offline "mock" mode with no keys set;
# add keys to switch each engine from simulated to live.
# ─────────────────────────────────────────────────────────────────────────

# --- LLM layer (single gateway for intent parsing, explanations, agent) ---
# Get a key at https://openrouter.ai/keys. Without it, the LLM steps fall back
# to deterministic heuristics.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
LLM_FAST_MODEL=openai/gpt-4o-mini

# --- Evo2 sequence model + scoring ---
# mock  = deterministic local model (default, no key needed)
# nim_api = NVIDIA-hosted Evo2 40B  (requires a key below)
# local = run a local Evo2 checkpoint (requires a GPU + EVO2_MODEL_PATH)
EVO2_MODE=mock
NVIDIA_API_KEY=
# EVO2_NIM_API_KEY / EVO2_KEY are accepted aliases for the NIM key.

# --- Protein structure prediction ---
# mock = deterministic placeholder (default) | esmfold = live api.esmatlas.com
STRUCTURE_MODE=mock

# --- NCBI E-utilities (NCBI / PubMed / ClinVar retrieval) ---
# Optional; raises rate limits from 3 to 10 req/s. https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=evo

# --- Gemini (literature detail summaries only - services/evidence_synthesis.py) ---
# Get a key at https://aistudio.google.com/apikey. Without it, literature
# evidence falls back to a truncated abstract instead of an LLM summary.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0
SESSION_STORE_MODE=memory
FRONTEND_URL=http://localhost:3000
PORT=8000

# --- Durable persistence (MongoDB Atlas) - OPTIONAL ---
# Redis stays the hot store; MongoDB durably records each design run (goal +
# config + resulting candidates), sessions, and experiment versions so history
# survives restarts / TTL expiry. Leave MONGODB_URI blank to run Redis-only:
# every persistence call becomes a logged no-op, nothing else changes.
# Atlas note: the connecting host's IP must be on the cluster's Network Access
# allowlist (Atlas → Network Access → Add IP). Otherwise the TLS handshake is
# rejected and the store stays disabled.
MONGODB_URI=
MONGODB_DB_NAME=evo

# --- Semantic vector search (research literature) - OPTIONAL ---
# Powers /api/literature/search. HYBRID embeddings: set EMBEDDING_API_KEY to use
# a real embedding model; leave it blank to use a deterministic local embedder
# that works offline with zero setup (lower quality, no network). Both emit
# EMBEDDING_DIM-length vectors. EMBEDDING_API_KEY falls back to OPENAI_API_KEY.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=256
# Atlas Vector Search index name over the `literature` collection. Provision it
# on the cluster to enable $vectorSearch; without it, search falls back to
# in-memory cosine similarity automatically. Create in Atlas → Search →
# Create Index → JSON editor with:
#   { "fields": [
#       { "type": "vector", "path": "embedding", "numDimensions": 256, "similarity": "cosine" },
#       { "type": "filter", "path": "gene" } ] }
VECTOR_INDEX_NAME=literature_vector_index
