# Backend API URL - where the Evo FastAPI backend is running.
# The backend returns WebSocket URLs in its /api/design response,
# so no separate WS URL config is needed.
#
# Examples:
#   NEXT_PUBLIC_API_URL=http://localhost:8000        # local backend
#   NEXT_PUBLIC_API_URL=http://192.168.1.100:8000    # backend on your LAN
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to "true" to allow UI-only mock fallbacks when the backend is unreachable.
# Leave unset in real use so failures surface instead of showing fake data.
NEXT_PUBLIC_ALLOW_UI_MOCKS=false
