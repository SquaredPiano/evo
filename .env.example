# ─────────────────────────────────────────────────────────────────────────
# Evo — environment configuration
# Copy this file to `.env` (repo root) and/or `backend/.env` and fill in keys.
# Everything works in a deterministic offline "mock" mode with no keys set;
# add keys to switch each engine from simulated to live.
# ─────────────────────────────────────────────────────────────────────────

# --- LLM layer (single gateway for intent parsing, explanations, agent) ---
# Get a key at https://openrouter.ai/keys. Without it, the LLM steps fall back
# to deterministic heuristics.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
LLM_FAST_MODEL=openai/gpt-4o-mini

# --- Evo2 sequence model + scoring ---
# mock  = deterministic local model (default, no key needed)
# nim_api = NVIDIA-hosted Evo2 40B  (requires a key below)
# local = run a local Evo2 checkpoint (requires a GPU + EVO2_MODEL_PATH)
EVO2_MODE=mock
NVIDIA_API_KEY=
# EVO2_NIM_API_KEY / EVO2_KEY are accepted aliases for the NIM key.

# --- Protein structure prediction ---
# mock = deterministic placeholder (default) | esmfold = live api.esmatlas.com
STRUCTURE_MODE=mock

# --- NCBI E-utilities (NCBI / PubMed / ClinVar retrieval) ---
# Optional; raises rate limits from 3 to 10 req/s. https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=evo

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0
SESSION_STORE_MODE=memory
FRONTEND_URL=http://localhost:3000
PORT=8000
